# Port to run the server on
PORT=5000

# Environment (development | production)
NODE_ENV=development

# MongoDB Connection URL
DB_URL=mongodb://localhost:27017/task-collaboration-db

# Authentication System (passport | custom)
AUTH_SYSTEM=custom

# JWT Secrets & Expirations (Must match schema inside env.ts)
JWT_ACCESS_SECRET=your_access_secret_key_here
JWT_ACCESS_EXPIRES=1d
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_REFRESH_EXPIRES=30d

# Verification / OTP Expiration (e.g. 5m, 10m)
OTP_EXPIRES=5m
RESET_PASS_EXPIRES=10m

# Password Hashing Cost Factor
BCRYPT_SALT_ROUND=10

# Frontend Client URL for CORS and OAuth redirects
FRONTEND_URL=http://localhost:3000

# Express Session Secret (required if AUTH_SYSTEM=passport)
EXPRESS_SESSION_SECRET=your_session_secret_here

# Super Admin / Demo Seeding Credentials (seeded automatically on startup)
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=Password123!

# Google OAuth (required if AUTH_SYSTEM=passport)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# Cloudinary Configuration (for task files and media)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# SMTP Email Configuration (for verification and resets)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FORM="CollabSphere <no-reply@collabsphere.com>"

# Redis configuration (optional)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
